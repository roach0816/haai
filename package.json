{
  "name": "haai",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "description": "Home Assistant AI appliance for read-only automation insights.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roach0816/haai.git"
  },
  "bugs": {
    "url": "https://github.com/roach0816/haai/issues"
  },
  "homepage": "https://github.com/roach0816/haai#readme",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.server.json && vite build",
    "release:package": "npm run build && node scripts/package-release.mjs",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "acme-client": "^5.4.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.1.2",
    "fastify": "^5.8.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "eslint": "^9.7.0",
    "globals": "^17.6.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19"
  }
}
